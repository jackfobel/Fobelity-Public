@page "/config/"

@attribute [Authorize(Roles = "MiniSplit.UserAccess")]

<PageTitle>Configuration</PageTitle>

<MudPaper Class="pa-4">
    <MudText Typo="Typo.h4" Class="mb-4">Configuration</MudText>

  @if (!IsInitialized || MiniSplitConfigData == null)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Class="mt-2"><em>Loading...</em></MudText>
    }
  else if (MiniSplitConfigData == null)
  {
    <MudText Color="Color.Error">Failed to load device details.</MudText>
  }
    else
    {
        <MudForm @ref="form">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 mb-4 minisplit-config">
                        <MudText Typo="Typo.h6">Cooling</MudText>
                        <MudDivider Class="mb-2" />

                        <MudTextField @bind-Value="MiniSplitConfigData.MiniSplitConfigCool.threshhold"
                          T="int"
                          Label="Temperature"
                          HelperText="Degrees F"
                          Variant="Variant.Outlined" />
                       
                          <MudSwitch 
                           @bind-Value="MiniSplitConfigData.MiniSplitConfigCool.enabled"
                           Label="Enabled"
                           Color="Color.Primary" />

                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 mb-4 minisplit-config">
                        <MudText Typo="Typo.h6">Heating</MudText>
                        <MudDivider Class="mb-2" />

                        <MudTextField @bind-Value="MiniSplitConfigData.MiniSplitConfigHeat.threshhold"
                          T="int"
                          Label="Temperature"
                          HelperText="Degrees F" 
                          Variant="Variant.Outlined" />

                        <MudSwitch @bind-Value="MiniSplitConfigData.MiniSplitConfigHeat.enabled"
                         Label="Enabled"
                         Color="Color.Primary" />

                    </MudPaper>
                </MudItem>
            </MudGrid>
      <MudButton OnClick="HandleClick" Color="Color.Primary" Variant="Variant.Filled" Class="mt-4">
        Save
      </MudButton>
        </MudForm>
    }
</MudPaper>

@code {
    private MudForm form;
}